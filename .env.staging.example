NODE_ENV=production
APP_URL=https://staging.hostelhub.example
NEXT_PUBLIC_APP_URL=https://staging.hostelhub.example
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/hostel_saas_staging
JWT_ACCESS_SECRET=replace-with-a-long-random-staging-access-secret-32
JWT_REFRESH_SECRET=replace-with-a-long-random-staging-refresh-secret-32
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX=5
OTP_HASH_SECRET=replace-with-a-long-random-staging-otp-secret-32
EMAIL_OTP_PROVIDER=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SMS_OTP_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_MESSAGING_SERVICE_SID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
COOKIE_DOMAIN=
COOKIE_SECURE=true
LOG_LEVEL=info
PUBLIC_FORM_RATE_LIMIT_MAX=8
PUBLIC_FORM_RATE_LIMIT_WINDOW_SECONDS=60
UPLOAD_MAX_IMAGE_BYTES=5242880
UPLOAD_MAX_DOCUMENT_BYTES=10485760
ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp
ALLOWED_DOCUMENT_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp
SEED_PLATFORM_OWNER_EMAIL=platform.owner@hostelhub.local
SEED_PLATFORM_OWNER_PHONE=
SEED_PLATFORM_OWNER_NAME=Platform Owner
SEED_PLATFORM_OWNER_PASSWORD=
DEMO_SEED_PASSWORD=
ADMIN_RECOVERY_EMAIL=
ADMIN_RECOVERY_PASSWORD=
ADMIN_RECOVERY_CONFIRM=
PRIVATE_DOCUMENT_CHECK_STRICT_MISSING=true
