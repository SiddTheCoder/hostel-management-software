# =============================================================
# Multi-Hostel SaaS Platform — environment template
# Copy to .env at the repo root and fill in real values.
# Never commit .env (only this .env.example is tracked).
# See docs/ENVIRONMENT.md for full documentation.
# =============================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (MongoDB Atlas or local MongoDB) ---
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority"

# --- Auth / JWT ---
JWT_ACCESS_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string-min-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# --- OTP (legacy signup flow) ---
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX=5
OTP_HASH_SECRET=replace-with-a-random-string

# --- Google OAuth (login) ---
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Google Maps Platform (optional — runtime fallback, Phase 2) ---
# Leave blank to use OpenStreetMap only (free).
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# --- Cloudflare R2 (S3-compatible file storage) ---
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=multi-hostel-uploads
# Public base URL for the bucket (only if public access is enabled), used by
# getPublicUrl() for public assets like hostel gallery photos.
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# --- Email (Resend) ---
RESEND_API_KEY=re_your_resend_api_key
# Sender resolution: EMAIL_FROM (full "Name <email>" header) wins; otherwise
# RESEND_FROM_NAME + RESEND_FROM_EMAIL are combined into "Name <email>".
EMAIL_FROM="Multi-Hostel Platform <no-reply@yourdomain.com>"
RESEND_FROM_NAME="Multi-Hostel Platform"
RESEND_FROM_EMAIL="no-reply@yourdomain.com"

# --- Seed / bootstrap (SUPERADMIN — created only by the seed script) ---
SEED_SUPERADMIN_EMAIL=admin@yourdomain.com
SEED_SUPERADMIN_NAME="Super Admin"
SEED_SUPERADMIN_PASSWORD=set-a-strong-one-time-password

# --- Cron secret (protects /api/v1/cron/* endpoints; scheduled via cron-job.org — see docs/CRON.md) ---
CRON_SECRET=replace-with-a-long-random-secret

# --- Cookies / logging ---
COOKIE_DOMAIN=
COOKIE_SECURE=false
LOG_LEVEL=info

# --- Firebase Cloud Messaging (Phase 6 only, leave blank until then) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=